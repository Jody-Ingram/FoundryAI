# Script  :  env.example
# Version :  1.0
# Date    :  7/8/2026
# Author: Jody Ingram
# Pre-reqs: N/A
# Notes: Example environment variables for your environment. Used with Firebase, Supabase, etc.


# Required server-side secrets
OPENAI_API_KEY=sk-your-key-here
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Optional chatbot settings
OPENAI_MODEL=gpt-5.5
OPENAI_REASONING=low
OPENAI_VERBOSITY=low
OPENAI_MAX_OUTPUT_TOKENS=700
BOT_INSTRUCTIONS=You are a friendly AI participant in a small shared group chat. Be concise and practical.
