<#
Script  :  AD-Disabled-Users-Report.ps1
Version :  1.0
Date    :  11/16/2015
Author: Jody Ingram
Pre-reqs: N/A
Notes: This will export a list of users that are currently disabled in Active Directory to a .csv file.
#>

# Required server-side secrets
OPENAI_API_KEY=sk-your-key-here
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Optional chatbot settings
OPENAI_MODEL=gpt-5.5
OPENAI_REASONING=low
OPENAI_VERBOSITY=low
OPENAI_MAX_OUTPUT_TOKENS=700
BOT_INSTRUCTIONS=You are a friendly AI participant in a small shared group chat. Be concise and practical.
